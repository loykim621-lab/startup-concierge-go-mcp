# 창업지원 컨시어지GO MCP — 환경변수 예시 (.env로 복사해 사용)
# 🔴 실제 키/토큰은 절대 코드·git에 커밋하지 마세요. .env는 .gitignore에 포함됨.

# --- 전송 방식 ---
# stdio(기본, 로컬·Inspector) 또는 http(배포·PlayMCP/카카오클라우드)
MCP_TRANSPORT=stdio

# --- HTTP transport 설정 (MCP_TRANSPORT=http 일 때) ---
PORT=8080
# 허용 Origin (CSRF/DNS rebinding 방어). 쉼표로 여러 개. 비우면 검사 안 함(배포 시 지정 권장).
MCP_ALLOWED_ORIGINS=

# --- 공고 수집기 (collector) ---
# K-Startup 공식 오픈 API는 인증키 불필요. 아래는 선택적 보강 소스용.
# 공공데이터포털(apis.data.go.kr) 인증키 — 기업마당 등 추가 수집 시. 없으면 K-Startup만 사용.
DATA_GO_KR_KEY=
# 수집 시 가져올 공고 수 상한
COLLECT_LIMIT=200
# 서버 자동 갱신 주기(시간). 기동 직후 1회 + 이 주기마다 K-Startup에서 재수집.
# 실패 시 기존 데이터 유지(fail-safe). 0이면 비활성. 기본 6.
AUTO_REFRESH_HOURS=6
# DRY_RUN=true면 외부 호출 없이 기존 스토어만 사용(첫 점검용)
DRY_RUN=false

# --- 데이터 계층 ---
# 기본은 로컬 JSON 스토어(data/grants.json). Supabase 사용 시 아래를 채우면 자동 전환.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
