{
  "name": "startup-concierge-go-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "창업지원 컨시어지GO — 정부 창업지원 공고 검색·자격검토·모의심사·합격전략 MCP 서버",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "concierge-go-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:http": "cross-env MCP_TRANSPORT=http tsx watch src/index.ts",
    "collect": "tsx src/collector/collect.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "docx": "^9.7.1",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
